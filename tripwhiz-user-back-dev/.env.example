TRIPWHIZ_JWT_SECRET=replace_with_at_least_32_bytes_random_secret
TRIPWHIZ_FIREBASE_CONFIG_PATH=file:/absolute/path/to/firebase-adminsdk.json
TRIPWHIZ_UPLOAD_DIR=C:\\upload
TRIPWHIZ_STORE_OWNER_URL=http://localhost:8082

# Required only when running with the mariadb Spring profile.
TRIPWHIZ_DB_URL=jdbc:mariadb://localhost:3306/tripwhiz
TRIPWHIZ_DB_USERNAME=tripwhiz
TRIPWHIZ_DB_PASSWORD=replace_with_database_password
